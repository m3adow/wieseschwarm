{
  "permissions": {
    "allow": [
      "Bash(cp talos/secret/controlplane.yaml /tmp/controlplane-before.yaml && echo \"Backup done\")",
      "Bash(cp talos/secret/controlplane.yaml /tmp/controlplane-before.yaml)",
      "Bash(git --version)",
      "Bash(git diff *)",
      "Bash(git ls-tree *)",
      "Bash(grep -Ev '^\\\\s+[A-Za-z0-9+/]{40,}=*\\\\s*$')",
      "Bash(helm repo *)",
      "Bash(helm search *)",
      "Bash(helm show *)",
      "Bash(kubectl -n piraeus-system get pods)",
      "Bash(kubectl explain *)",
      "Bash(kubectl get *)",
      "Bash(kustomize build *)",
      "Bash(npx --yes --package renovate@latest -- renovate-config-validator --strict renovate.json)",
      "Bash(talosctl config *)",
      "Bash(xargs ls -la)",
      "Bash(yamllint *)",
      "Skill(code-review)",
      "Skill(code-review:*)",
      "WebFetch(domain:argo-cd.readthedocs.io)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:docs.siderolabs.com)",
      "WebFetch(domain:endoflife.date)",
      "mcp__argocd__get_application",
      "mcp__argocd__get_application_managed_resources",
      "mcp__argocd__list_applications",
      "mcp__argocd__list_clusters",
      "mcp__kubernetes__events_list",
      "mcp__kubernetes__namespaces_list",
      "mcp__kubernetes__nodes_stats_summary",
      "mcp__kubernetes__pods_list_in_namespace",
      "mcp__kubernetes__pods_log",
      "mcp__kubernetes__resources_get",
      "mcp__kubernetes__resources_list"
    ],
    "additionalDirectories": ["/tmp"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f || exit 0; [[ \"$f\" == *.yaml ]] || exit 0; [[ \"$f\" =~ /talos/ || \"$f\" =~ /kubernetes/ ]] || exit 0; root=$(git -C \"$(dirname \"$f\")\" rev-parse --show-toplevel 2>/dev/null) || exit 0; cd \"$root\" && pre-commit run --files \"$(realpath --relative-to=\"$root\" \"$f\")\"; }",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f || exit 0; [[ \"$f\" == *.md ]] || exit 0; root=$(git -C \"$(dirname \"$f\")\" rev-parse --show-toplevel 2>/dev/null) || exit 0; cd \"$root\" && git check-ignore -q \"$f\" 2>/dev/null && exit 0; pre-commit run prettier --files \"$(realpath --relative-to=\"$root\" \"$f\")\" 2>/dev/null || true; }",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
